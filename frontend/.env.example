# frontend/.env.example — copia como .env y rellena los valores reales
# NUNCA commitear .env (ya está en .gitignore de este directorio)

# Supabase → Dashboard → Project Settings → API
# URL base del proyecto (sin trailing slash, sin /rest/v1 ni ningún path)
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública anon/publishable (safe en el cliente, protegida por RLS)
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Las variables PUBLIC_* de SvelteKit se exponen al cliente vía $env/static/public.
# Las variables sin prefijo PUBLIC_ solo están disponibles en +page.server.js / hooks.server.js.
