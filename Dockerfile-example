# ==============================================================================
# Multi-stage Dockerfile para Next.js + Golang en un solo contenedor
# Compatible con Render.com
# ==============================================================================

# ------------------------------------------------------------------------------
# Stage 1: Build Golang Backend
# ------------------------------------------------------------------------------
FROM golang:1.23-alpine AS go-builder

WORKDIR /build

# Instalar dependencias del sistema necesarias para compilar
RUN apk add --no-cache git

# Copiar archivos de dependencias de Go
COPY backend/go.mod backend/go.sum ./

# Descargar dependencias
RUN go mod download

# Copiar código fuente del backend
COPY backend/*.go ./

# Compilar binario estático de Go
# CGO_ENABLED=0 para crear un binario completamente estático
# -ldflags="-w -s" reduce el tamaño del binario
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -o api-server \
    .

# ------------------------------------------------------------------------------
# Stage 2: Build Next.js Frontend
# ------------------------------------------------------------------------------
FROM node:22-alpine AS frontend-builder

WORKDIR /build

# Copiar archivos de dependencias de Node
COPY package*.json ./

# Instalar dependencias (incluyendo devDependencies para el build)
RUN npm ci

# Copiar código fuente del frontend
COPY . .

ENV NEXT_PUBLIC_API_URL="https://cygnus-inventario.onrender.com"

# Construir aplicación Next.js para producción
RUN npm run build

# ------------------------------------------------------------------------------
# Stage 3: Runtime - Imagen final con ambos servicios
# ------------------------------------------------------------------------------
FROM node:22-alpine

# Instalar dependencias del sistema necesarias en runtime
RUN apk add --no-cache \
    bash \
    curl \
    ca-certificates

# Crear usuario no-root para seguridad
RUN addgroup -g 1001 appgroup && \
    adduser -D -u 1001 -G appgroup appuser

WORKDIR /app

# Copiar binario de Go desde go-builder
COPY --from=go-builder --chown=appuser:appgroup /build/api-server /app/api-server

# Copiar build de Next.js desde frontend-builder
COPY --from=frontend-builder --chown=appuser:appgroup /build/.next /app/.next
COPY --from=frontend-builder --chown=appuser:appgroup /build/node_modules /app/node_modules
COPY --from=frontend-builder --chown=appuser:appgroup /build/package.json /app/package.json
COPY --from=frontend-builder --chown=appuser:appgroup /build/public /app/public

# Copiar script de inicio
COPY --chown=appuser:appgroup start.sh /app/start.sh
RUN chmod +x /app/start.sh

# Cambiar a usuario no-root
USER appuser

# Exponer puerto (Render usa la variable PORT)
EXPOSE 3000

# Health check para Render
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Ejecutar script de inicio que maneja ambos procesos
CMD ["/app/start.sh"]